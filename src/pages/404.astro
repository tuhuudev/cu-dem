---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_NAME } from "../consts";
---

<BaseLayout
  title={`Không tìm thấy trang — ${SITE_NAME}`}
  description={`Trang bạn tìm không tồn tại hoặc đã bị di chuyển trên ${SITE_NAME}.`}
  type="website"
>
  <section class="page-intro not-found">
    <p class="code" aria-hidden="true">404</p>
    <h1>Không tìm thấy trang</h1>
    <p>Trang bạn tìm không tồn tại hoặc đã bị di chuyển. Thử tìm bài viết bạn cần nhé.</p>
    <div class="actions">
      <a class="cta-button" href="/">← Về trang chủ</a>
      <a class="cta-button secondary" href="/tim-kiem">Tìm kiếm bài viết</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 1rem;
  }
  .not-found .code {
    margin: 0;
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--accent, #3b82f6);
  }
  .not-found h1 { margin: 0.5rem 0 0.75rem; }
  .not-found .actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .cta-button {
    display: inline-block;
    background: var(--primary, #2563eb);
    color: #fff;
    font-weight: 700;
    padding: 10px 24px;
    border-radius: 12px;
    text-decoration: none;
  }
  .cta-button:hover { opacity: 0.92; text-decoration: none; }
  .cta-button.secondary {
    background: var(--bg-soft, #f3f4f6);
    color: var(--text, #111827);
    border: 1px solid var(--border, #e5e7eb);
  }
</style>
