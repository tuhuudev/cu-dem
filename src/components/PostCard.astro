---
import {
  formatDate,
  isoDate,
  postUrl,
  categoryUrl,
  ogImageFor,
  categoryGradientCss,
} from "../utils";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  ogImage?: string;
  readingTime: string;
}
const { title, description, pubDate, category, ogImage, readingTime } =
  Astro.props;
const url = postUrl(title);
const image = ogImageFor(title, ogImage);
---

<li class="post-card">
  <a href={url} class="thumb-link" aria-label={title}>
    <img
      class="thumb"
      src={image}
      alt={title}
      width="1200"
      height="630"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="body">
    <div class="meta">
      <a class="badge" href={categoryUrl(category)} style={`background:${categoryGradientCss(category)}`}>{category}</a>
      <span class="dot">{readingTime}</span>
    </div>
    <h3><a href={url}>{title}</a></h3>
    <p>{description}</p>
    <div class="meta" style="margin-top:14px">
      <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
    </div>
  </div>
</li>
