---
import {
  SITE_NAME,
  SITE_URL,
  SITE_DESCRIPTION,
  SITE_LANG,
  DEFAULT_OG_IMAGE,
  DEFAULT_AUTHOR,
  SITE_LOGO,
  SOCIAL_LINKS,
  TWITTER_HANDLE,
} from "../consts";

interface Crumb {
  name: string;
  url?: string;
}
interface VideoMeta {
  /** YouTube video ID (11 ký tự) */
  id: string;
  title?: string;
  description?: string;
  /** ISO date (mặc định = publishDate) */
  uploadDate?: string;
}

interface Props {
  title: string;
  description?: string;
  /** Đường dẫn ảnh OG (tương đối hoặc tuyệt đối) */
  image?: string;
  /** "website" cho trang chủ, "article" cho bài viết */
  type?: "website" | "article";
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  tags?: string[];
  /** Breadcrumb cho JSON-LD BreadcrumbList (name + url tuyệt đối/tương đối) */
  breadcrumbs?: Crumb[];
  /** Video YouTube nhúng trong bài -> JSON-LD VideoObject (video rich result) */
  video?: VideoMeta;
  /** Bài tin/thời sự -> dùng schema NewsArticle (freshness cho Google News) */
  news?: boolean;
  /** Trang hồ sơ tác giả (E-E-A-T) -> author.url trong JSON-LD */
  authorUrl?: string;
  /** Câu hỏi thường gặp -> JSON-LD FAQPage (FAQ rich result) */
  faq?: { q: string; a: string }[];
  /** Điểm review (0-5) + tên công cụ -> JSON-LD Review (review snippet sao) */
  rating?: number;
  ratingTool?: string;
  ratingSummary?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = DEFAULT_OG_IMAGE,
  type = "website",
  publishDate,
  modifiedDate,
  author = DEFAULT_AUTHOR,
  tags = [],
  breadcrumbs = [],
  video,
  news = false,
  authorUrl,
  faq = [],
  rating,
  ratingTool,
  ratingSummary,
} = Astro.props;

// URL tuyệt đối của trang hiện tại -> canonical chuẩn
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
// Ảnh OG luôn ở dạng tuyệt đối (Facebook yêu cầu)
const ogImageURL = new URL(image, SITE_URL).href;
const abs = (u: string) => new URL(u, SITE_URL).href;

// Tiêu đề trên tab: "Tiêu đề bài | Tên trang"
const fullTitle =
  title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;

// ---- JSON-LD: gom nhiều thực thể vào @graph ----
const org = {
  "@type": "Organization",
  "@id": `${SITE_URL}#org`,
  name: SITE_NAME,
  url: SITE_URL,
  logo: { "@type": "ImageObject", url: abs(SITE_LOGO) },
  ...(SOCIAL_LINKS.length ? { sameAs: SOCIAL_LINKS } : {}),
};

const graph: Record<string, unknown>[] = [org];

if (type === "article") {
  graph.push({
    "@type": news ? "NewsArticle" : "BlogPosting",
    headline: title,
    description,
    image: ogImageURL,
    inLanguage: SITE_LANG,
    datePublished: publishDate?.toISOString(),
    dateModified: (modifiedDate ?? publishDate)?.toISOString(),
    author: {
      "@type": "Person",
      name: author,
      ...(authorUrl ? { url: abs(authorUrl) } : {}),
    },
    publisher: { "@id": `${SITE_URL}#org` },
    ...(tags.length ? { keywords: tags.join(", ") } : {}),
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
    // Speakable -> trợ lý giọng nói có thể đọc tóm tắt (khớp tính năng audio).
    speakable: {
      "@type": "SpeakableSpecification",
      cssSelector: [".article-lead", ".takeaways"],
    },
  });
} else if (Astro.url.pathname === "/") {
  // WebSite (+ SearchAction) chỉ khai báo ở trang chủ — tránh lặp thực thể trên mọi trang.
  graph.push({
    "@type": "WebSite",
    "@id": `${SITE_URL}#website`,
    name: SITE_NAME,
    description,
    url: SITE_URL,
    inLanguage: SITE_LANG,
    publisher: { "@id": `${SITE_URL}#org` },
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${SITE_URL}/tim-kiem?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  });
}

// VideoObject khi bài có nhúng video YouTube -> đủ điều kiện video rich result
if (video?.id) {
  graph.push({
    "@type": "VideoObject",
    name: video.title ?? title,
    description: video.description ?? description,
    thumbnailUrl: [`https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`],
    uploadDate: video.uploadDate ?? publishDate?.toISOString(),
    contentUrl: `https://www.youtube.com/watch?v=${video.id}`,
    embedUrl: `https://www.youtube.com/embed/${video.id}`,
  });
}

// FAQPage khi bài có câu hỏi thường gặp -> đủ điều kiện FAQ rich result
if (faq.length) {
  graph.push({
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  });
}

// Review khi bài có chấm điểm 1 công cụ -> review snippet (sao) trên Google.
// Đây là đánh giá biên tập của Cú Đêm về sản phẩm bên thứ ba (hợp lệ với Google).
if (typeof rating === "number" && ratingTool) {
  graph.push({
    "@type": "Review",
    itemReviewed: {
      "@type": "SoftwareApplication",
      name: ratingTool,
      applicationCategory: "BusinessApplication",
    },
    reviewRating: {
      "@type": "Rating",
      ratingValue: rating,
      bestRating: 5,
      worstRating: 1,
    },
    ...(ratingSummary ? { reviewBody: ratingSummary } : {}),
    author: { "@id": `${SITE_URL}#org` },
    publisher: { "@id": `${SITE_URL}#org` },
    datePublished: publishDate?.toISOString(),
  });
}

// BreadcrumbList khi có breadcrumb
if (breadcrumbs.length) {
  graph.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((c, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: c.name,
      ...(c.url ? { item: abs(c.url) } : {}),
    })),
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---

<!-- Cơ bản -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph (Facebook hiển thị thẻ preview từ đây) -->
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content={SITE_LANG === "vi" ? "vi_VN" : "en_US"} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
{
  type === "article" && publishDate && (
    <meta
      property="article:published_time"
      content={publishDate.toISOString()}
    />
  )
}
{
  type === "article" && modifiedDate && (
    <meta
      property="article:modified_time"
      content={modifiedDate.toISOString()}
    />
  )
}
{
  type === "article" &&
    tags.map((tag) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
{TWITTER_HANDLE && <meta name="twitter:site" content={TWITTER_HANDLE} />}
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Structured Data -->
<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
