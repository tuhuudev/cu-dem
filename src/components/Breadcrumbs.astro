---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Breadcrumb" data-pagefind-ignore>
  {
    items.map((item, i) => (
      <>
        {i > 0 && <span class="sep">/</span>}
        {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
      </>
    ))
  }
</nav>
