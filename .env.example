# Sao chep file nay thanh ".env" roi dien gia tri that. File .env KHONG duoc commit.

# === Gemini (tao bai + anh) ===
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# === Anh cover ===
# Nguon anh:
#   "source" (mac dinh): uu tien anh og:image tu bai NGUON tim duoc + ghi nguon; khong co -> stock.
#              LUU Y: anh bao chi co the co ban quyen - uu tien nguon cho dung lai, luon ghi nguon.
#   "stock" : chi dung anh co giay phep (Pexels/Pixabay/Wikimedia) - an toan ban quyen.
#   "gemini": anh AI (can bat billing).
IMAGE_SOURCE=source
# Tuy chon cho stock, deu mien phi (khong co thi dung Wikimedia - khong can key):
PEXELS_API_KEY=
PIXABAY_API_KEY=
# Ghi chu: noi dung BAT BUOC co nguon that (grounding, dung chung GEMINI_API_KEY).
# Khong lay duoc nguon -> bo bai. Dung --no-grounding de viet chay khi can.

# === Video YouTube (tuy chon) ===
# Can key de tim video LIEN QUAN va CHO PHEP NHUNG (videoEmbeddable=true). Khong co key -> bo qua video.
# Lay free: console.cloud.google.com -> bat "YouTube Data API v3" -> Create API key.
YOUTUBE_API_KEY=

# === Cloudflare R2 (kho anh + video) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gxg-media
R2_PUBLIC_BASE=https://pub-xxxxxxxx.r2.dev

# === Cloudflare Pages Deploy Hook (tuy chon: goi de build lai) ===
# Noi dung la cac file .md trong src/content/posts -> git push se tu build.
# Bien nay chi can neu muon trigger build ma khong qua git.
DEPLOY_HOOK_URL=
