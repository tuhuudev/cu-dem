{
  "name": "cu-dem",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "ai:post": "node scripts/generate-ai-post.mjs",
    "ai:trends": "node scripts/fetch-trends.mjs",
