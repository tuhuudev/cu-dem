    "astro": "^5.7.0",
    "aws4fetch": "^1.0.20",
    "gray-matter": "^4.0.3",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
